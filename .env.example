# Raiz / CI — copie para `.env` local conforme o app que estiver a correr.

# --- API (apps/api) ---
NODE_ENV=development
# api = HTTP Nest (predefinido) | worker = apenas consumidores BullMQ
PROCESS_ROLE=api
DATABASE_URL="postgresql://navomnis:navomnis@localhost:5432/navomnis?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_ACCESS_SECRET="change-me-access-min-32-chars-long-secret"
JWT_REFRESH_SECRET="change-me-refresh-min-32-chars-long-secret"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"
API_PORT=4000
# Origens CORS (CSV). Em produção deve listar URLs reais (ex.: https://app.exemplo.com,https://*.vercel.app se aplicável).
WEB_URL="http://localhost:5173"
# Em produção: omitir ou false. Só true em ambientes privados/staging com credenciais abaixo.
SWAGGER_ENABLED=""
# Obrigatório em produção quando SWAGGER_ENABLED=true (Basic Auth em /api/docs).
SWAGGER_BASIC_USER=""
SWAGGER_BASIC_PASSWORD=""
RESEND_API_KEY=""
SENTRY_DSN_API=""
# --- Open Finance Brasil (apps/api) ---
# false até prova V1 (docs/open-finance/v1-gate.md)
OPEN_FINANCE_ENABLED=false
ENCRYPTION_KEY=""
OF_DIRECTORY_URL=""
OF_CLIENT_ID=""
OF_REDIRECT_URI="http://localhost:4000/api/v1/banking/oauth/callback"
# MTLS_CERT="" MTLS_KEY="" (produção/homologação)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""

# --- Web (apps/web / Vite) ---
# Em build de produção (Vercel) é obrigatório definir a URL pública da API (ex.: https://api.seudominio.com/api/v1).
VITE_API_URL="http://localhost:4000/api/v1"
VITE_APP_ENV=development
VITE_PROXY_API="http://localhost:4000"
VITE_SENTRY_DSN=""
VITE_PUSH_PUBLIC_KEY=""
VITE_GOOGLE_CLIENT_ID=""
VITE_APPLE_CLIENT_ID=""

# --- Vercel (local / CI; não commitar tokens) ---
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
# VERCEL_TOKEN=

# --- Railway (local / CI; não commitar tokens) ---
# RAILWAY_TOKEN=
