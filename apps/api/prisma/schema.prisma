  scopes         Json?
  expiresAt      DateTime?
  authorisedAt   DateTime?
  revokedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  connection   BankConnection       @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  authorizer   User?                @relation("BankConsentAuthorizer", fields: [authorizedById], references: [id], onDelete: SetNull)
  oauthSession BankOAuthSession?
  credential   BankCredentialVault?
  syncJobs     BankSyncJob[]

  @@index([tenantId, companyId, status])
  @@index([connectionId])
}

model BankOAuthSession {
  id           String    @id @default(uuid())
  tenantId     String
  consentId    String    @unique
  state        String    @unique
  codeVerifier String
  redirectUri  String
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime  @default(now())

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  consent BankConsent @relation(fields: [consentId], references: [id], onDelete: Cascade)

  @@index([tenantId, expiresAt])
}

model BankCredentialVault {
  id            String    @id @default(uuid())
  tenantId      String
  consentId     String    @unique
  keyVersion    Int       @default(1)
  accessCipher  String
  accessIv      String
  refreshCipher String?
  refreshIv     String?
  expiresAt     DateTime?
  rotatedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  consent BankConsent @relation(fields: [consentId], references: [id], onDelete: Cascade)

  @@index([tenantId, consentId])
}

model BankAccount {
  id            String          @id @default(uuid())
  tenantId      String
  companyId     String
  connectionId  String
  branchId      String?
  externalId    String
  accountType   BankAccountType @default(CHECKING)
  branchNumber  String?
  accountNumber String
  checkDigit    String?
  currency      String          @default("BRL")
  displayName   String?
  isActive      Boolean         @default(true)
  lastSyncAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company      Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  connection   BankConnection    @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  balances     BankBalance[]
  transactions BankTransaction[]

  @@unique([tenantId, connectionId, externalId])
  @@index([tenantId, companyId])
}

model BankBalance {
  id        String   @id @default(uuid())
  tenantId  String
  companyId String
  accountId String
  amount    Decimal  @db.Decimal(18, 2)
  asOf      DateTime
  createdAt DateTime @default(now())

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  account BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([tenantId, accountId, asOf])
}

model BankTransaction {
  id              String              @id @default(uuid())
  tenantId        String
  companyId       String
  accountId       String
  externalId      String
  transactionType BankTransactionType @default(OTHER)
  amount          Decimal             @db.Decimal(18, 2)
  bookedAt        DateTime
  description     String?
  documentNumber  String?
  rawPayload      Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tenant    Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company   Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  account   BankAccount           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  pixDetail PixTransactionDetail?
  matches   ReconciliationMatch[]

  @@unique([tenantId, accountId, externalId])
  @@index([tenantId, companyId, bookedAt])
  @@index([tenantId, accountId, transactionType])
}

model PixTransactionDetail {
  id               String   @id @default(uuid())
  transactionId    String   @unique
  endToEndId       String?
  pixKey           String?
  counterpartyName String?
  counterpartyDoc  String?
  createdAt        DateTime @default(now())

  transaction BankTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([endToEndId])
}

model BankSyncJob {
  id           String            @id @default(uuid())
  tenantId     String
  connectionId String
  consentId    String?
  jobType      BankSyncJobType
  status       BankSyncJobStatus @default(PENDING)
  cursor       String?
  errorMessage String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime          @default(now())

  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection BankConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  consent    BankConsent?   @relation(fields: [consentId], references: [id], onDelete: SetNull)

  @@index([tenantId, connectionId, status])
}

model BankWebhookInbox {
  id          String    @id @default(uuid())
  tenantId    String?
  eventId     String
  eventType   String
  payload     Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@unique([eventId])
  @@index([tenantId, processedAt])
}

model ReconciliationRule {
  id              String   @id @default(uuid())
  tenantId        String
  companyId       String
  name            String
  amountTolerance Decimal  @default(0.01) @db.Decimal(18, 4)
  dayTolerance    Int      @default(3)
  matchers        Json
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([tenantId, companyId, isActive])
}

model ReconciliationMatch {
  id                String                    @id @default(uuid())
  tenantId          String
  companyId         String
  bankTransactionId String
  targetType        String
  targetId          String?
  status            ReconciliationMatchStatus @default(SUGGESTED)
  confidence        Decimal                   @db.Decimal(5, 4)
  matchedById       String?
  postedAt          DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company         Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bankTransaction BankTransaction @relation(fields: [bankTransactionId], references: [id], onDelete: Cascade)

  @@index([tenantId, companyId, status])
  @@index([bankTransactionId])
}

model BankingAccessLog {
  id        String              @id @default(uuid())
  tenantId  String
  companyId String?
  userId    String
  action    BankingAccessAction
  resource  String?
  ip        String?
  metadata  Json?
  createdAt DateTime            @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, createdAt])
}

// --- Platform SaaS administration ---

model PlatformOperator {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  displayName  String
  mfaEnabled   Boolean   @default(false)
  mfaSecret    String?
  totpPending  Boolean   @default(false)
  blockedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  operatorRoles       PlatformOperatorRole[]
  refreshTokens       PlatformRefreshToken[]
  sessions            PlatformSession[]
  auditLogs           AuditLog[]
  publishedLegalDocs  LegalDocumentVersion[]
  loginHistories      PlatformLoginHistory[]
  userInvites         UserInvite[]
}

model PlatformPermission {
  id   String @id @default(uuid())
  code String @unique
  name String

  rolePermissions PlatformRolePermission[]
}

model PlatformRole {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions PlatformRolePermission[]
  operatorRoles   PlatformOperatorRole[]
}

model PlatformRolePermission {
  roleId       String
  permissionId String

  role       PlatformRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission PlatformPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model PlatformOperatorRole {
  id         String @id @default(uuid())
  operatorId String
  roleId     String

  operator PlatformOperator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  role     PlatformRole     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([operatorId, roleId])
}

model PlatformRefreshToken {
  id          String    @id @default(uuid())
  operatorId  String
  jti         String    @unique
  hashedToken String
  ip          String?
  userAgent   String?
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  operator PlatformOperator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId, revokedAt])
}

model PlatformSession {
  id               String    @id @default(uuid())
  operatorId       String
  deviceFingerprint String?
  ip               String?
  userAgent        String?
  lastSeenAt       DateTime  @default(now())
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  operator PlatformOperator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId, revokedAt])
}

model PlatformLoginHistory {
  id         String   @id @default(uuid())
  operatorId String
  ip         String?
  userAgent  String?
  success    Boolean
  reason     String?
  createdAt  DateTime @default(now())

  operator PlatformOperator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId, createdAt])
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String?
  ip        String?
  userAgent String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model DeviceRegistry {
  id                String   @id @default(uuid())
  userId            String
  fingerprint       String
  userAgent         String?
  lastIp            String?
  lastSeenAt        DateTime @default(now())
  trusted           Boolean  @default(false)
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
}

model SubscriptionPlan {
  id           String               @id @default(uuid())
  code         String               @unique
  name         String
  planType     SubscriptionPlanType
  description  String?
  priceCents   Int                  @default(0)
  currency     String               @default("BRL")
  billingCycle String               @default("monthly")
  trialDays    Int                  @default(0)
  isActive     Boolean              @default(true)
  archivedAt   DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  features      PlanFeature[]
  quotas        PlanQuota[]
  subscriptions TenantSubscription[]
}

model PlanFeature {
  id        String  @id @default(uuid())
  planId    String
  moduleKey String
  enabled   Boolean @default(true)

  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, moduleKey])
}

model PlanQuota {
  id        String        @id @default(uuid())
  planId    String
  resource  QuotaResource
  limitValue Int

  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, resource])
}

model TenantSubscription {
  id                 String                   @id @default(uuid())
  tenantId           String                   @unique
  planId             String
  status             TenantSubscriptionStatus @default(TRIAL)
  currentPeriodStart DateTime                 @default(now())
  currentPeriodEnd   DateTime?
  graceEndsAt        DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([planId, status])
}

model TenantUsageSnapshot {
  id        String        @id @default(uuid())
  tenantId  String
  resource  QuotaResource
  usedValue Int
  periodKey String
  createdAt DateTime      @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, resource, periodKey])
}

model TenantFeatureOverride {
  id        String   @id @default(uuid())
  tenantId  String
  moduleKey String
  enabled   Boolean
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleKey])
}

model TelemetryEvent {
  id        String             @id @default(uuid())
  kind      TelemetryEventKind
  tenantId  String?
  payload   Json?
  createdAt DateTime           @default(now())

  @@index([kind, createdAt])
  @@index([tenantId, createdAt])
}

model ApiUsageRollup {
  id           String   @id @default(uuid())
  tenantId     String?
  routePattern String
  count        Int
  periodKey    String
  createdAt    DateTime @default(now())

  @@unique([tenantId, routePattern, periodKey])
}

model QueueHealthSnapshot {
  id          String   @id @default(uuid())
  queueName   String
  waiting     Int
  active      Int
  failed      Int
  completed   Int
  capturedAt  DateTime @default(now())

  @@index([queueName, capturedAt])
}

model DataSubjectRequest {
  id          String                   @id @default(uuid())
  tenantId    String
  userId      String?
  email       String?
  requestType DataSubjectRequestType
  status      DataSubjectRequestStatus @default(OPEN)
  notes       String?
  completedAt DateTime?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
}

model DataRetentionPolicy {
  id            String   @id @default(uuid())
  category      String   @unique
  retentionDays Int
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
