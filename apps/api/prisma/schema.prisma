generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  PROVISIONING
  BLOCKED
  EXPIRED
  TRIAL
  PENDING_ACTIVATION
}

enum AuditScope {
  TENANT
  PLATFORM
}

enum SubscriptionPlanType {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
  CUSTOM
}

enum TenantSubscriptionStatus {
  ACTIVE
  TRIAL
  PAST_DUE
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum QuotaResource {
  USERS
  COMPANIES
  BRANCHES
  STORAGE_MB
  API_CALLS
  BANK_INTEGRATIONS
  INVENTORY_RECORDS
  INVOICES
  NOTIFICATIONS
  AI_USAGE
  QUEUE_JOBS
}

enum DataSubjectRequestType {
  EXPORT
  DELETE
  ANONYMIZE
}

enum DataSubjectRequestStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  REJECTED
  CANCELLED
}

enum LegalDocumentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum TelemetryEventKind {
  API_REQUEST
  QUEUE_JOB
  LOGIN
  MODULE_USAGE
  ERROR
  HEALTH_CHECK
}

enum PartyKind {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum DocumentStatus {
  DRAFT
  OPEN
  RELEASED
  POSTED
  CANCELLED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}

enum NotificationType {
  PURCHASE_ORDER_CONFIRMED
  SALES_ORDER_CONFIRMED
  GOODS_RECEIPT
  INVOICE_OVERDUE
  APPROVAL_PENDING
  PASSWORD_RESET
  PENDING_TASKS
  STATUS_CHANGED
  SUSPICIOUS_LOGIN
  FINANCIAL_ALERT
  FISCAL_ALERT
}

enum ConsentKind {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  MARKETING
  COOKIES_ANALYTICS
}

enum FiscalJurisdictionLevel {
  FEDERAL
  STATE
  MUNICIPAL
  FOREIGN
}

enum BrazilianFiscalRegime {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
  MEI
  RURAL_PRODUCER
  EXEMPT
}

enum TaxpayerType {
  CONTRIBUTOR
  NON_CONTRIBUTOR
  EXEMPT
  CONSUMER
  FOREIGN
}

enum FiscalDocumentDirection {
  OUTBOUND
  INBOUND
}

enum FiscalDocumentKind {
  SALES_QUOTE
  SALES_ORDER
  SALES_INVOICE
  SALES_CREDIT_NOTE
  SALES_RETURN
  PURCHASE_ORDER
  GOODS_RECEIPT
  PURCHASE_INVOICE
  SERVICE_INVOICE
  TAX_ADJUSTMENT
}

enum FiscalDocumentAuthorizationStatus {
  DRAFT
  VALIDATED
  PENDING_AUTHORIZATION
  AUTHORIZED
  REJECTED
  CANCELLED
  CONTINGENCY
  POSTED
}

enum BrazilianTaxKind {
  ICMS
  ICMS_ST
  IPI
  ISS
  PIS
  COFINS
  DIFAL
  FCP
  IRRF
  CSLL
  INSS
  FUNRURAL
  FREIGHT_TAX
  IMPORT_DUTY
  IBS
  CBS
  IS
}

enum TaxRuleBaseStrategy {
  LINE_AMOUNT
  DOCUMENT_AMOUNT
  CUSTOMS_VALUE
  FREIGHT_AMOUNT
  SERVICE_AMOUNT
  PREVIOUS_TAX_AMOUNT
  FORMULA
}

enum PostingJournalStatus {
  DRAFT
  PREVIEWED
  VALIDATED
  POSTED
  CANCELLED
}

enum LedgerSide {
  DEBIT
  CREDIT
}

enum FiscalRegisterStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum ItemFiscalType {
  MERCHANDISE
  RAW_MATERIAL
  FINISHED_GOOD
  FIXED_ASSET
  CONSUMABLE
  FUEL
  IMPORTED
  SERVICE_BUNDLE
  OTHER
}

enum ServiceFiscalType {
  SERVICE
  COMMUNICATION
  TRANSPORT
  CONSTRUCTION
  DIGITAL
  PUBLIC_SERVICE
  OTHER
}

enum LaborRegime {
  CLT
  STATUTORY
  APPRENTICE
  INTERN
  CONTRACTOR
  DIRECTOR
  TEMPORARY
  OTHER
}

enum WeightControlType {
  FIXED_QUANTITY
  VARIABLE_WEIGHT
  CATCH_WEIGHT
}

enum WarehouseZoneType {
  AMBIENT
  COLD_ROOM
  RIPENING
  RECEIVING
  PICKING
  EXPEDITION
  QUARANTINE
  WASTE
}

enum ProduceLotStatus {
  AVAILABLE
  QUARANTINED
  RESERVED
  EXPIRED
  CONSUMED
  DISCARDED
}

enum QualityInspectionStatus {
  PENDING
  APPROVED
  PARTIALLY_APPROVED
  REJECTED
}

enum InventoryLossReason {
  SPOILAGE
  SHRINKAGE
  DAMAGE
  QUALITY_RECLASSIFICATION
  WEIGHT_VARIANCE
  THEFT
  OTHER
}

enum DeliveryRouteStatus {
  PLANNED
  LOADING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum LandedCostAllocationBasis {
  WEIGHT
  VALUE
  QUANTITY
  MANUAL
}

model Tenant {
  id            String       @id @default(uuid())
  slug          String       @unique
  name          String
  legalName     String?
  status        TenantStatus @default(PROVISIONING)
  timezone      String       @default("America/Sao_Paulo")
  defaultLanguage String     @default("pt-BR")
  countryCode   String?      @default("BR")
  taxId         String?
  retentionDays Int?
  trialEndsAt   DateTime?
  suspendedAt   DateTime?
  blockedAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  branding                 TenantBranding?
  subscription             TenantSubscription?
  usageSnapshots           TenantUsageSnapshot[]
  featureOverrides         TenantFeatureOverride[]
  consentRecords           ConsentRecord[]
  dataSubjectRequests      DataSubjectRequest[]
  userTenants              UserTenant[]
  userInvites              UserInvite[]
  companies                Company[]
  parties                  Party[]
  items                    Item[]
  roles                    Role[]
  notifications            Notification[]
  auditLogs                AuditLog[]
  salesOrders              SalesOrder[]
  purchaseOrders           PurchaseOrder[]
  itemLedger               ItemLedgerEntry[]
  glAccounts               ChartOfAccount[]
  glEntries                GlEntry[]
  workflows                ApprovalWorkflow[]
  opportunities            Opportunity[]
  outboxEvents             OutboxEvent[]
  attachments              Attachment[]
  notificationPreferences  NotificationPreference[]
  numberSeries             DocumentNumberSeries[]
  fiscalJurisdictions      FiscalJurisdiction[]
  fiscalRegimeSetups       FiscalRegimeSetup[]
  taxAreas                 TaxArea[]
  taxGroups                TaxGroup[]
  fiscalOperationTypes     FiscalOperationType[]
  taxDeterminationRules    TaxDeterminationRule[]
  productFiscalProfiles    ProductFiscalProfile[]
  partyFiscalProfiles      PartyFiscalProfile[]
  itemFiscalTemplates      ItemFiscalTemplate[]
  serviceFiscalTemplates   ServiceFiscalTemplate[]
  companyFiscalProfiles    CompanyFiscalProfile[]
  branches                 Branch[]
  branchFiscalProfiles     BranchFiscalProfile[]
  employees                Employee[]
  employeeTaxProfiles      EmployeeTaxProfile[]
  agriculturalItemProfiles AgriculturalItemProfile[]
  packagingTypes           PackagingType[]
  warehouses               Warehouse[]
  warehouseZones           WarehouseZone[]
  inventoryLots            InventoryLot[]
  qualityInspections       QualityInspection[]
  inventoryLossEvents      InventoryLossEvent[]
  inventoryValueEntries    InventoryValueEntry[]
  landedCostAllocations    LandedCostAllocation[]
  deliveryRoutes           DeliveryRoute[]
  fiscalDocuments          FiscalDocument[]
  fiscalDocumentLines      FiscalDocumentLine[]
  fiscalDocumentLineTaxes  FiscalDocumentLineTax[]
  postingJournals          PostingJournal[]
  postingJournalLines      PostingJournalLine[]
  postingSetups            PostingSetup[]
  taxPostingSetups         TaxPostingSetup[]
  fiscalPostingSetups      FiscalPostingSetup[]
  customerLedgerEntries    CustomerLedgerEntry[]
  supplierLedgerEntries    SupplierLedgerEntry[]
  bankLedgerEntries        BankLedgerEntry[]
  taxLedgerEntries         TaxLedgerEntry[]
  taxSettlementEntries     TaxSettlementLedgerEntry[]
  financialInstitutions    FinancialInstitution[]
  bankConnections          BankConnection[]
  bankConsents             BankConsent[]
  bankOAuthSessions        BankOAuthSession[]
  bankAccounts             BankAccount[]
  bankBalances             BankBalance[]
  bankTransactions         BankTransaction[]
  bankSyncJobs             BankSyncJob[]
  bankWebhookInbox         BankWebhookInbox[]
  reconciliationRules      ReconciliationRule[]
  reconciliationMatches    ReconciliationMatch[]
  bankingAccessLogs        BankingAccessLog[]
}

model DocumentNumberSeries {
  id         String   @id @default(uuid())
  tenantId   String
  code       String
  lastNumber Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
}

model TenantBranding {
  id               String   @id @default(uuid())
  tenantId         String   @unique
  logoUrl          String?
  faviconUrl       String?
  legalDisplayName String?
  customDomain     String?  @unique
  primaryColor     String?  @default("#0f172a")
  accentColor      String?  @default("#2563eb")
  emailFooter      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String?
  displayName  String
  locale       String    @default("pt-BR")
  mfaEnabled   Boolean   @default(false)
  mfaSecret    String?
  blockedAt    DateTime?
  forcePasswordResetAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  refreshTokens       RefreshToken[]
  loginHistories      LoginHistory[]
  devices             DeviceRegistry[]
  accounts            Account[]
  userTenants         UserTenant[]
  userCompanies       UserCompany[]
  userRoles           UserRole[]
  accessLogs          AccessLog[]
  consentRecords      ConsentRecord[]
  notificationPrefs   NotificationPreference[]
  notifications       Notification[]           @relation("NotificationUser")
  auditLogs           AuditLog[]               @relation("AuditActor")
  createdParties      Party[]                  @relation("PartyCreatedBy")
  updatedParties      Party[]                  @relation("PartyUpdatedBy")
  qualityInspections  QualityInspection[]      @relation("QualityInspector")
  inventoryLossEvents InventoryLossEvent[]     @relation("InventoryLossCreatedBy")
  bankConsents        BankConsent[]            @relation("BankConsentAuthorizer")
  bankingAccessLogs   BankingAccessLog[]
  userInvites         UserInvite[]
}

model UserInvite {
  id          String    @id @default(uuid())
  userId      String
  email       String
  displayName String
  tenantId    String
  tokenHash   String    @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  invitedById String?
  createdAt   DateTime  @default(now())

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy PlatformOperator? @relation(fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([email, tenantId])
}

model Account {
  id                String   @id @default(uuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String
  jti         String    @unique
  hashedToken String
  userAgent   String?
  ip          String?
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserTenant {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model Company {
  id        String    @id @default(uuid())
  tenantId  String
  name      String
  taxId     String?
  isHead    Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant                Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userCompanies         UserCompany[]
  salesOrders           SalesOrder[]
  purchaseOrders        PurchaseOrder[]
  fiscalRegimes         FiscalRegimeSetup[]
  fiscalDocuments       FiscalDocument[]
  postingJournals       PostingJournal[]
  customerLedgerEntries CustomerLedgerEntry[]
  supplierLedgerEntries SupplierLedgerEntry[]
  bankLedgerEntries     BankLedgerEntry[]
  taxLedgerEntries      TaxLedgerEntry[]
  taxSettlementEntries  TaxSettlementLedgerEntry[]
  fiscalProfiles        CompanyFiscalProfile[]
  branches              Branch[]
  employees             Employee[]
  bankConnections       BankConnection[]
  bankConsents          BankConsent[]
  bankAccounts          BankAccount[]
  bankTransactions      BankTransaction[]
  bankBalances          BankBalance[]
  reconciliationRules   ReconciliationRule[]
  reconciliationMatches ReconciliationMatch[]

  @@index([tenantId, name])
}

model UserCompany {
  id        String   @id @default(uuid())
  userId    String
  companyId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([tenantId, name])
}

model Permission {
  id   String @id @default(uuid())
  code String @unique
  name String

  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model Party {
  id          String    @id @default(uuid())
  tenantId    String
  kind        PartyKind
  name        String
  taxId       String?
  email       String?
  phone       String?
  creditLimit Decimal?  @db.Decimal(18, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  version     Int       @default(1)
  createdById String?
  updatedById String?

  tenant                Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy             User?                     @relation("PartyCreatedBy", fields: [createdById], references: [id])
  updatedBy             User?                     @relation("PartyUpdatedBy", fields: [updatedById], references: [id])
  salesOrders           SalesOrder[]              @relation("SalesOrderCustomer")
  purchaseOrders        PurchaseOrder[]           @relation("PurchaseOrderVendor")
  fiscalProfile         PartyFiscalProfile?
  fiscalDocuments       FiscalDocument[]
  customerLedgerEntries CustomerLedgerEntry[]
  supplierLedgerEntries SupplierLedgerEntry[]
  producedItemProfiles  AgriculturalItemProfile[] @relation("AgriculturalProducer")
  producedLots          InventoryLot[]            @relation("LotProducer")

  @@index([tenantId, kind, name])
}

model Item {
  id                   String    @id @default(uuid())
  tenantId             String
  sku                  String
  name                 String
  baseUom              String    @default("UN")
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?
  version              Int       @default(1)
  itemFiscalTemplateId String?

  tenant                Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  itemFiscalTemplate    ItemFiscalTemplate?      @relation(fields: [itemFiscalTemplateId], references: [id], onDelete: SetNull)
  ledger                ItemLedgerEntry[]
  salesLines            SalesOrderLine[]
  purchaseLines         PurchaseOrderLine[]
  fiscalProfile         ProductFiscalProfile?
  fiscalDocumentLines   FiscalDocumentLine[]
  agriculturalProfile   AgriculturalItemProfile?
  inventoryLots         InventoryLot[]
  qualityInspections    QualityInspection[]
  inventoryLossEvents   InventoryLossEvent[]
  inventoryValueEntries InventoryValueEntry[]

  @@unique([tenantId, sku])
  @@index([tenantId, itemFiscalTemplateId])
}

model ChartOfAccount {
  id        String   @id @default(uuid())
  tenantId  String
  code      String
  name      String
  isPosting Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  glEntries GlEntry[]

  @@unique([tenantId, code])
}

model GlEntry {
  id           String   @id @default(uuid())
  tenantId     String
  postingDate  DateTime
  accountId    String
  description  String?
  debit        Decimal  @default(0) @db.Decimal(18, 2)
  credit       Decimal  @default(0) @db.Decimal(18, 2)
  documentType String?
  documentId   String?
  createdAt    DateTime @default(now())

  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account ChartOfAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([tenantId, postingDate])
}

model SalesOrder {
  id          String         @id @default(uuid())
  tenantId    String
  companyId   String
  customerId  String
  number      String
  status      DocumentStatus @default(DRAFT)
  orderDate   DateTime       @default(now())
  totalAmount Decimal        @default(0) @db.Decimal(18, 2)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  version     Int            @default(1)

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company  Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Party            @relation("SalesOrderCustomer", fields: [customerId], references: [id], onDelete: Restrict)
  lines    SalesOrderLine[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, companyId, orderDate])
  @@index([tenantId, customerId, orderDate])
}

model SalesOrderLine {
  id            String   @id @default(uuid())
  orderId       String
  itemId        String
  quantity      Decimal  @db.Decimal(18, 4)
  unitPrice     Decimal  @db.Decimal(18, 4)
  lineTotal     Decimal  @db.Decimal(18, 2)
  lotId         String?
  packageTypeId String?
  grossWeightKg Decimal? @db.Decimal(18, 4)
  tareWeightKg  Decimal? @db.Decimal(18, 4)
  netWeightKg   Decimal? @db.Decimal(18, 4)
  qualityGrade  String?

  order       SalesOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item        Item           @relation(fields: [itemId], references: [id], onDelete: Restrict)
  lot         InventoryLot?  @relation(fields: [lotId], references: [id], onDelete: Restrict)
  packageType PackagingType? @relation(fields: [packageTypeId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([lotId])
}

model PurchaseOrder {
  id          String         @id @default(uuid())
  tenantId    String
  companyId   String
  vendorId    String
  number      String
  status      DocumentStatus @default(DRAFT)
  orderDate   DateTime       @default(now())
  totalAmount Decimal        @default(0) @db.Decimal(18, 2)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  version     Int            @default(1)

  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company               Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor                Party                  @relation("PurchaseOrderVendor", fields: [vendorId], references: [id], onDelete: Restrict)
  lines                 PurchaseOrderLine[]
  qualityInspections    QualityInspection[]
  landedCostAllocations LandedCostAllocation[]

  @@unique([tenantId, number])
  @@index([tenantId, vendorId, orderDate])
  @@index([tenantId, companyId, orderDate])
}

model PurchaseOrderLine {
  id                 String   @id @default(uuid())
  orderId            String
  itemId             String
  quantity           Decimal  @db.Decimal(18, 4)
  unitCost           Decimal  @db.Decimal(18, 4)
  lineTotal          Decimal  @db.Decimal(18, 2)
  lotId              String?
  packageTypeId      String?
  grossWeightKg      Decimal? @db.Decimal(18, 4)
  tareWeightKg       Decimal? @db.Decimal(18, 4)
  netWeightKg        Decimal? @db.Decimal(18, 4)
  qualityGrade       String?
  freightCostAmount  Decimal  @default(0) @db.Decimal(18, 2)
  handlingCostAmount Decimal  @default(0) @db.Decimal(18, 2)
  landedCostAmount   Decimal  @default(0) @db.Decimal(18, 2)

  order       PurchaseOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item        Item           @relation(fields: [itemId], references: [id], onDelete: Restrict)
  lot         InventoryLot?  @relation(fields: [lotId], references: [id], onDelete: Restrict)
  packageType PackagingType? @relation(fields: [packageTypeId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([lotId])
}

model ItemLedgerEntry {
  id           String   @id @default(uuid())
  tenantId     String
  itemId       String
  quantity     Decimal  @db.Decimal(18, 4)
  lotId        String?
  warehouseId  String?
  zoneId       String?
  valueEntryId String?
  entryType    String
  documentType String?
  documentId   String?
  postingDate  DateTime @default(now())
  createdAt    DateTime @default(now())

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  item       Item                 @relation(fields: [itemId], references: [id], onDelete: Cascade)
  lot        InventoryLot?        @relation(fields: [lotId], references: [id], onDelete: Restrict)
  warehouse  Warehouse?           @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  zone       WarehouseZone?       @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  valueEntry InventoryValueEntry? @relation(fields: [valueEntryId], references: [id], onDelete: SetNull)

  @@index([tenantId, itemId, postingDate])
  @@index([tenantId, lotId, postingDate])
  @@index([tenantId, warehouseId, zoneId])
}

model ApprovalWorkflow {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  module    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  steps  ApprovalStep[]
}

model ApprovalStep {
  id         String @id @default(uuid())
  workflowId String
  stepOrder  Int
  name       String

  workflow ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  tasks    ApprovalTask[]
}

model ApprovalTask {
  id        String   @id @default(uuid())
  stepId    String
  status    String   @default("PENDING")
  payload   Json?
  createdAt DateTime @default(now())

  step ApprovalStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
}

model Opportunity {
  id        String   @id @default(uuid())
  tenantId  String
  title     String
  stage     String
  amount    Decimal? @db.Decimal(18, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id @default(uuid())
  tenantId  String
  userId    String
  type      NotificationType
  title     String
  body      String
  readAt    DateTime?
  metadata  Json?
