// --- Open Finance Brasil (banking aggregation) ---

enum BankConnectionStatus {
  PENDING_CONSENT
  ACTIVE
  SUSPENDED
  ERROR
  REVOKED
}

enum BankConsentStatus {
  AWAITING_AUTHORISATION
  AUTHORISED
  REJECTED
  EXPIRED
  REVOKED
}

enum BankAccountType {
  CHECKING
  SAVINGS
  PREPAID
  PAYMENT
  OTHER
}

enum BankTransactionType {
  CREDIT
  DEBIT
  PIX
  TED
  DOC
  BOLETO
  CARD
  FEE
  TRANSFER
  OTHER
}

enum BankSyncJobType {
  ACCOUNTS
  BALANCES
  TRANSACTIONS_HISTORICAL
  TRANSACTIONS_INCREMENTAL
  CONSENT_CHECK
}

enum BankSyncJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ReconciliationMatchStatus {
  SUGGESTED
  CONFIRMED
  REJECTED
  POSTED
}

enum BankingAccessAction {
  READ_ACCOUNTS
  READ_TRANSACTIONS
  START_CONSENT
  REVOKE_CONSENT
  SYNC
  RECONCILE
}

model FinancialInstitution {
  id              String   @id @default(uuid())
  tenantId        String?
  participantId   String
